generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model FileStatus {
  id        String     @id @default(cuid())
  filename  String
  folder    String
  isPublic  Boolean    @default(false)
  ownerId   String?
  user      User?      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  size      Int        @default(0)
  burnToken BurnToken?

  @@unique([folder, filename])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                   String    @id @default(cuid())
  name                 String?
  fullName             String?   // For Hash Auditor Certification
  documentId           String?   // For Hash Auditor Certification
  certificationAuth    String?   // Extra credentials for reports
  email                String?   @unique
  emailVerified        DateTime?
  image                String?
  policyAcceptedAt     DateTime?
  lastSeenAt           DateTime? @default(now())
  deadManSwitchDays    Int?      
  deadManTriggerAction String?   @default("LOCKDOWN") // LOCKDOWN or DELETE_ALL
  
  // NCFN Plan & Quota Tracking
  role                 String    @default("user") // admin, user
  planType             String    @default("TRIAL") // TRIAL, PRO
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  proAccessUntil       DateTime?
  uploadedFilesCount   Int       @default(0)
  totalBytesUsed       Int       @default(0) // Safe up to 9PB in JS

  // TOTP 2FA
  totpSecret           String?
  totpEnabled          Boolean   @default(false)

  accounts             Account[]
  sessions             Session[]
  aiConfig             UserAiConfig?
  files                FileStatus[]
  trashItems           TrashItem[]          @relation(name: "UserTrashItems")
  webAuthnCredentials  WebAuthnCredential[]
}

model UserAiConfig {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  geminiKey       String?
  openaiKey       String?
  preferredModel  String   @default("gemini-1.5-pro")
  updatedAt       DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model GuestEmail {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  active           Boolean   @default(true)
  policyAcceptedAt DateTime?
  createdAt        DateTime  @default(now())
}

model GuestAccessLog {
  id          String   @id @default(cuid())
  email       String
  ip          String?
  loginAt     DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  sessionMins Int      @default(0)
}

model TrashItem {
  id           String   @id @default(cuid())
  filename     String
  folder       String
  originalPath String
  deletedAt    DateTime @default(now())
  size         Int
  mtime        DateTime
  ownerId      String?
  user         User?    @relation(name: "UserTrashItems", fields: [ownerId], references: [id], onDelete: SetNull)
}

model SharedLink {
  id        String   @id @default(cuid())
  token     String   @unique
  folder    String
  filename  String
  expiresAt DateTime
  maxViews  Int?     // null means unlimited within time limit
  views     Int      @default(0)
  createdAt DateTime @default(now())
}

model ForensicInvestigation {
  id            String   @id @default(cuid())
  target        String
  tool          String
  command       String
  rawOutput     String
  aiReport      String?
  sha256Hash    String
  operatorEmail String
  createdAt     DateTime @default(now())
}

model OsintKeyword {
  id          String   @id @default(cuid())
  keyword     String   @unique
  category    String   // e.g. "Tráfico", "Corrupção", "Crimes Digitais"
  legalRef    String?  // CP/CPP reference e.g. "Art. 33 Lei 11.343/06"
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  scans       OsintScheduledScan[]
}

model OsintScheduledScan {
  id            String        @id @default(cuid())
  keywordId     String
  keyword       OsintKeyword  @relation(fields: [keywordId], references: [id])
  tool          String        // sherlock | theharvester
  target        String        // derived from keyword
  command       String
  rawOutput     String
  aiReport      String?
  sha256Hash    String
  status        String        @default("success") // success | error | timeout
  errorMessage  String?
  durationSecs  Float?
  triggeredBy   String        @default("cron") // cron | manual
  createdAt     DateTime      @default(now())
}


model InvestigationTarget {
  id        String   @id @default(cuid())
  url       String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model BurnToken {
  id         String     @id @default(cuid())
  fileId     String     @unique
  file       FileStatus @relation(fields: [fileId], references: [id], onDelete: Cascade)
  folder     String
  filename   String
  token      String     @unique
  consumed   Boolean    @default(false)
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  @@unique([folder, filename])
}

model TimestampRecord {
  id        String   @id @default(cuid())
  sha256    String   @unique
  filename  String?
  folder    String?
  captureId String?
  tsrBase64 String   // RFC 3161 TSR binary (base64)
  tsaUrl    String   @default("https://freetsa.org/tsr")
  createdAt DateTime @default(now())
}

model LaudoForense {
  id              String   @id @default(cuid())
  titulo          String
  numeroCaso      String?
  operatorEmail   String
  evidencias      String   // JSON: array of {filename, folder, hash, type}
  metodologia     String?
  achados         String?  // AI-generated findings
  conclusao       String?  // AI-generated conclusion
  quesitos        String?  // Custom questions
  pdfFile         String?
  status          String   @default("rascunho") // rascunho | final
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CanaryFile {
  id              String    @id @default(cuid())
  filename        String
  folder          String
  description     String?
  alertEmail      String
  accessCount     Int       @default(0)
  lastAccessedAt  DateTime?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())

  @@unique([folder, filename])
}

model WebAuthnCredential {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String    @unique
  publicKey    String
  counter      Int       @default(0)
  transports   String?
  deviceName   String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?
}

model WebAuthnChallenge {
  id        String   @id @default(cuid())
  userId    String
  challenge String
  expiresAt DateTime

  @@index([userId])
}

model OsintSection {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  icon      String   @default("BookOpen")
  content   String   // markdown content
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OsintInvestigation {
  id          String   @id @default(cuid())
  filename    String
  size        Int
  sha256      String
  storedPath  String
  notes       String?
  uploadedBy  String
  createdAt   DateTime @default(now())
}

model WebCapture {
  id              String   @id @default(cuid())
  url             String
  profile         String   @default("completa") // rapida | completa | deep
  operatorEmail   String
  serverIp        String?
  serverLocation  String?
  sslIssuer       String?
  sslExpiry       String?
  sslFingerprint  String?
  whoisData       String?
  httpHeaders     String?
  screenshotFile  String?
  pdfFile         String?
  htmlFile        String?
  harFile         String?
  hashScreenshot  String?
  hashPdf         String?
  hashHtml        String?
  rfcTimestamp     String?
  certidaoPdf      String?
  webCheckData     String?   // JSON: {dns,ssl,ip,tech,headers,cookies,robots,ports}
  waybackUrl       String?   // URL salva no archive.org
  blockchainTx     String?   // Hash submetido ao OriginStamp
  blockchainVerify String?   // https://originstamp.com/v/{hash}
  pingMs           Int?      // Latência em ms
  siteStatus       Int?      // HTTP status code
  status           String   @default("processing") // processing | done | error
  errorMessage     String?
  createdAt        DateTime @default(now())
}

model AuditLog {
  id             String   @id @default(cuid())
  actionType     String   @default("AFERICAO_CRUZADA")
  providedHash   String
  calculatedHash String
  isMatch        Boolean
  ipAddress      String?
  userAgent      String?
  userId         String?
  createdAt      DateTime @default(now())
}

model PurgeLog {
  id                String   @id @default(cuid())
  fileName          String
  originalHash      String
  originalFolder    String
  deletionDate      DateTime @default(now())
  managerId         String
  justification     String?
  destructionMethod String   @default("STANDARD_DELETE")
  createdAt         DateTime @default(now())
}

model DeadMansSwitch {
  id              String   @id @default(cuid())
  userId          String   @unique
  isActive        Boolean  @default(false)
  latencyDays     Int      @default(7)
  terminalAction  String   @default("LOCKDOWN")
  emergencyEmails String?
  lastCheckIn     DateTime @default(now())
  lastCheckInIp   String?
  updatedAt       DateTime @updatedAt
}

model FileViewer {
  id        String    @id @default(cuid())
  folder    String
  filename  String
  email     String
  expiresAt DateTime? // null = permanent; set = limited access (e.g. 48h)
  createdAt DateTime  @default(now())

  @@unique([folder, filename, email])
  @@index([email])
  @@index([folder, filename])
}

model VaultAccessLog {
  id        String   @id @default(cuid())
  filePath  String   // "folder/filename"
  action    String   // read | download | custody | pericia | delete | trash | canary
  userEmail String
  ip        String?
  isCanary  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([filePath])
  @@index([createdAt])
}

model VitrinePublish {
  id            String   @id @default(cuid())
  folder        String
  filename      String
  recipientName String
  passwordHash  String   // bcrypt or sha256 hash of 6-digit code
  passwordIndex Int      @default(0)  // 1-20: number shown next to the code in the vitrine
  publishedAt   DateTime @default(now())
  downloadCount Int      @default(0)
  active        Boolean  @default(true)
}
