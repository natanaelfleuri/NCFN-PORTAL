generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model FileStatus {
  id       String   @id @default(cuid())
  filename String
  folder   String
  isPublic Boolean  @default(false)

  @@unique([folder, filename])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                   String    @id @default(cuid())
  name                 String?
  email                String?   @unique
  emailVerified        DateTime?
  image                String?
  policyAcceptedAt     DateTime?
  lastSeenAt           DateTime? @default(now())
  deadManSwitchDays    Int?      
  deadManTriggerAction String?   @default("LOCKDOWN") // LOCKDOWN or DELETE_ALL
  accounts             Account[]
  sessions             Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model GuestEmail {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  active           Boolean   @default(true)
  policyAcceptedAt DateTime?
  createdAt        DateTime  @default(now())
}

model GuestAccessLog {
  id          String   @id @default(cuid())
  email       String
  ip          String?
  loginAt     DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  sessionMins Int      @default(0)
}

model TrashItem {
  id           String   @id @default(cuid())
  filename     String
  folder       String
  originalPath String
  deletedAt    DateTime @default(now())
  size         Int
  mtime        DateTime
}

model SharedLink {
  id        String   @id @default(cuid())
  token     String   @unique
  folder    String
  filename  String
  expiresAt DateTime
  maxViews  Int?     // null means unlimited within time limit
  views     Int      @default(0)
  createdAt DateTime @default(now())
}

model ForensicInvestigation {
  id            String   @id @default(cuid())
  target        String
  tool          String
  command       String
  rawOutput     String
  aiReport      String?
  sha256Hash    String
  operatorEmail String
  createdAt     DateTime @default(now())
}

model OsintKeyword {
  id          String   @id @default(cuid())
  keyword     String   @unique
  category    String   // e.g. "Tráfico", "Corrupção", "Crimes Digitais"
  legalRef    String?  // CP/CPP reference e.g. "Art. 33 Lei 11.343/06"
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  scans       OsintScheduledScan[]
}

model OsintScheduledScan {
  id            String        @id @default(cuid())
  keywordId     String
  keyword       OsintKeyword  @relation(fields: [keywordId], references: [id])
  tool          String        // sherlock | theharvester
  target        String        // derived from keyword
  command       String
  rawOutput     String
  aiReport      String?
  sha256Hash    String
  status        String        @default("success") // success | error | timeout
  errorMessage  String?
  durationSecs  Float?
  triggeredBy   String        @default("cron") // cron | manual
  createdAt     DateTime      @default(now())
}

model MoltbotConfig {
  id              String   @id @default("default")
  geminiKey       String?  // Optional, can be overridden by .env
  dailyQuotaBRL   Float    @default(10.0)
  currentUsageBRL Float    @default(0.0)
  activeMode      String   @default("HYBRID") // HYBRID, OLLAMA_ONLY, GEMINI_ONLY
  lastScanAt      DateTime?
  updatedAt       DateTime @updatedAt
}

model MoltbotLog {
  id            String   @id @default(cuid())
  taskName      String
  status        String   // success, failure, stopped_by_quota
  logText       String
  screenshotPath String?
  sha256Hash    String
  costBRL       Float    @default(0.0)
  createdAt     DateTime @default(now())
}
model InvestigationTarget {
  id        String   @id @default(cuid())
  url       String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
