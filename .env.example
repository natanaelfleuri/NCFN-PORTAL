# PORTAL NCFN — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# ─── NEXTAUTH ─────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=gere-com-openssl-rand-base64-32

# ─── GOOGLE OAUTH ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-client-secret

# ─── ADMIN ────────────────────────────────────────────────────────────────
ADMIN_EMAIL=seu-email@gmail.com

# ─── IA / OLLAMA ──────────────────────────────────────────────────────────
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=mistral
OLLAMA_VISION_MODEL=llava          # para análise de imagens (ollama pull llava)

# ─── WHISPER ASR (FASE 5.2 — perfil whisper) ──────────────────────────────
# Ativar: docker compose --profile whisper up -d
WHISPER_URL=http://whisper:9000

# ─── CHROMADB RAG (FASE 5.3 — perfil rag) ────────────────────────────────
# Ativar: docker compose --profile rag up -d
CHROMA_URL=http://chromadb:8000

# ─── EMAIL (SMTP — para alertas canary e notificações) ────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-app-password-gmail

# ─── CRIPTOGRAFIA ─────────────────────────────────────────────────────────
# Gerar: openssl rand -base64 32
CRYPTO_SALT=gere-com-openssl-rand-base64-32
JWT_SECRET=gere-com-openssl-rand-base64-32

# ─── DEAD MAN SWITCH ──────────────────────────────────────────────────────
# Gerar: openssl rand -hex 32
MASTER_UNLOCK_KEY=gere-com-openssl-rand-hex-32

# ─── CRON ─────────────────────────────────────────────────────────────────
# Gerar: openssl rand -hex 24
CRON_SECRET=gere-com-openssl-rand-hex-24

# ─── CLOUDFLARE TURNSTILE ─────────────────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=sua-site-key
TURNSTILE_SECRET_KEY=sua-secret-key

# ─── OSINT DESKTOP (Ubuntu/XFCE via noVNC — substitui Kasm) ──────────────
# Ativar: docker compose --profile osint up -d
# Requer ~2-4GB RAM (vs 16GB do Kasm Workspaces)
OSINT_DESKTOP_URL=http://localhost:3003
OSINT_DESKTOP_PASSWORD=OsintNcfn@2026!

# ─── DATABASE (FASE 7 — migração para PostgreSQL) ─────────────────────────
# DATABASE_URL=postgresql://ncfn:senha@postgres:5432/ncfn_db

# ─── REDIS (FASE 7) ───────────────────────────────────────────────────────
# REDIS_URL=redis://redis:6379

# ─── RFC 3161 TIMESTAMP (FASE 3) ──────────────────────────────────────────
# FREETSA_URL=https://freetsa.org/tsr
